APP_NAME="Teton County Cemetery Records"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://choteau.cemetery.tetonmt.gov
APP_DOMAIN=cemetery.tetonmt.gov

CEMETERY_DEFAULT_SLUG=choteau
CEMETERY_COUNTY=Teton
CEMETERY_STATE=MT

# Admin seeder credentials (used once on first db:seed)
ADMIN_NAME="Cemetery Admin"
ADMIN_EMAIL=admin@cemetery.tetonmt.gov
ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cemetery
DB_USERNAME=cemetery
DB_PASSWORD=
DB_ROOT_PASSWORD=

NGINX_PORT=80

BROADCAST_CONNECTION=log
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Local dev overrides — copy to .env and adjust
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://choteau.cemetery.test
# APP_DOMAIN=cemetery.test
# LOG_LEVEL=debug
# NGINX_PORT=8880
