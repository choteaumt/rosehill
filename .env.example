APP_NAME="Teton County Cemetery Records"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://cemetery.test
APP_DOMAIN=cemetery.test

CEMETERY_DEFAULT_SLUG=choteau
CEMETERY_COUNTY=Teton
CEMETERY_STATE=MT

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cemetery
DB_USERNAME=cemetery
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

VITE_APP_NAME="${APP_NAME}"
